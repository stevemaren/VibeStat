{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Lets the main window open/save datasets and export graphs (SVG/PNG/PDF/CSV) via native dialogs, read/write user-picked files, copy graph images to the clipboard, and be dragged by its custom title strip (frameless macOS).",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "core:menu:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "clipboard-manager:allow-write-image"
  ]
}
